# LLM Provider: "openai" (Ollama/OpenAI-compatible), "anthropic", or "cerebras"
LLM_PROVIDER=openai

# OpenAI-compatible (when LLM_PROVIDER=openai, e.g. Ollama)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen2.5:14b

# Anthropic (when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-20250514

# Cerebras (when LLM_PROVIDER=cerebras)
# CEREBRAS_API_KEY=csk-...
# LLM_MODEL=zai-glm-4.7

HMAC_SECRET=generate-a-random-64-char-hex-string
PORT=3001

# Web search (SearXNG instance)
SEARXNG_URL=http://localhost:8080

# Session file storage
SESSION_FILE_DIR=/tmp/ai-interface-sessions

# CORS origin (default: http://localhost:5173, set to http://localhost:8080 for Docker)
# CORS_ORIGIN=http://localhost:5173

# Query Augmenter (preprocesses queries with a smaller model)
# AUGMENTER_ENABLED=true
# AUGMENTER_MODEL=gpt-4o-mini
